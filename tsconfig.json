{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "strictPropertyInitialization": false,
    "useUnknownInCatchVariables": false,
    "jsx": "react-jsx",
    "paths": {
      "@app/*": ["./*"],
      "@server/*": ["./seerr/server/*"],
      "@seerr/*": ["./seerr/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "nativewind-env.d.ts"]
}
